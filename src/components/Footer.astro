---
import ObfuscatedEmail from './ObfuscatedEmail.astro';
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="film-strip"></div>
  <div class="footer-inner container">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <span class="footer-logo-mark">S</span>
        <span>Strategy<span style="color:var(--gold)">&</span></span>
      </a>
      <p class="footer-tagline">後悔しない人生のために、<br>すべての選択肢を可視化する</p>
    </div>

    <div class="footer-links">
      <div class="footer-col">
        <p class="footer-col-title">Company</p>
        <ul>
          <li><a href="/about">About / MVV</a></li>
          <li><a href="/news">News</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <p class="footer-col-title">Services</p>
        <ul>
          <li><a href="/services/shinkan-movie">新歓映画館</a></li>
          <li><a href="/#services">新歓プラットフォーム</a></li>
          <li><a href="/#services">学祭プラットフォーム</a></li>
          <li><a href="/#services">機会リマインド</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <p class="footer-col-title">Contact</p>
        <ul>
          <li><a href="/contact">お問い合わせフォーム</a></li>
          <li><ObfuscatedEmail user="info" domain="strategy-and.art" /></li>
        </ul>
      </div>
    </div>
  </div>

  <div class="footer-bottom container">
    <p>&copy; {year} Strategy&amp;. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: #050505;
    padding-top: 0;
  }
  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 64px;
    padding-top: 64px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 18px;
    font-weight: 900;
    margin-bottom: 20px;
  }
  .footer-logo-mark {
    width: 32px;
    height: 32px;
    background: var(--gold);
    color: var(--bg-dark);
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 900;
  }
  .footer-tagline {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    line-height: 1.8;
  }

  .footer-links { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .footer-col-title {
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: rgba(255,180,0,0.6);
    margin-bottom: 16px;
  }
  .footer-col ul { list-style: none; }
  .footer-col ul li { margin-bottom: 10px; }
  .footer-col ul li a {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    transition: color var(--transition);
  }
  .footer-col ul li a:hover { color: rgba(255,255,255,0.85); }

  .footer-bottom {
    padding-top: 24px;
    padding-bottom: 24px;
  }
  .footer-bottom p {
    font-size: 12px;
    color: rgba(255,255,255,0.2);
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; gap: 40px; }
    .footer-links { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .footer-links { grid-template-columns: 1fr; }
  }
</style>
