---
import Layout from '../layouts/Layout.astro';

// ★ Formspreeのフォームエンドポイントを設定してください
// 1. https://formspree.io/ でアカウント作成（無料）
// 2. New Form → メールアドレスを入力 → Form ID をコピー
// 3. 下の FORMSPREE_ID を置き換え
const FORMSPREE_ID = 'YOUR_FORM_ID'; // 例: "xpzgkwqr"
---

<Layout
  title="お問い合わせ | Strategy&"
  description="Strategy&へのお問い合わせ。広告掲載・新歓映画館・大学祭プラットフォーム・新歓プラットフォームに関するご相談はこちらから。"
>

  <!-- ヒーロー -->
  <section class="page-hero">
    <div class="film-strip"></div>
    <div class="container page-hero-inner">
      <p class="section-label">Contact</p>
      <h1 class="page-hero-title">お問い合わせ</h1>
      <p class="page-hero-sub">まずは、話を聞いてみませんか？</p>
    </div>
    <div class="film-strip film-strip--bottom"></div>
  </section>

  <!-- フォーム -->
  <section class="section section--light">
    <div class="contact-wrap container">

      <!-- サイドバー -->
      <aside class="contact-aside">
        <div class="aside-card">
          <p class="aside-label">対応サービス</p>
          <ul class="aside-services">
            <li>
              <span class="aside-icon">🎬</span>
              <div>
                <strong>新歓映画館企画</strong>
                <p>PV制作・映画館上映・<br>新入生へのリーチ</p>
              </div>
            </li>
            <li>
              <span class="aside-icon">📋</span>
              <div>
                <strong>新歓プラットフォーム</strong>
                <p>デジタル新歓パンフレット<br>の導入・運営</p>
              </div>
            </li>
            <li>
              <span class="aside-icon">🎪</span>
              <div>
                <strong>大学祭プラットフォーム</strong>
                <p>学祭のデジタル化・<br>プラットフォーム提供</p>
              </div>
            </li>
            <li>
              <span class="aside-icon">📢</span>
              <div>
                <strong>広告掲載</strong>
                <p>学生・新入生への<br>ターゲット広告枠</p>
              </div>
            </li>
          </ul>
        </div>
        <div class="aside-card aside-card--dark">
          <p class="aside-label aside-label--gold">直接メール</p>
          <a href="mailto:info@strategy-and.art" class="aside-email">
            info@strategy-and.art
          </a>
        </div>
      </aside>

      <!-- フォーム本体 -->
      <div class="form-wrap">
        <form
          id="contact-form"
          action={`https://formspree.io/f/${FORMSPREE_ID}`}
          method="POST"
          novalidate
        >
          <!-- お問い合わせ区分 -->
          <fieldset class="form-fieldset">
            <legend class="form-legend">
              お問い合わせ区分 <span class="required">必須</span>
            </legend>
            <div class="radio-group">
              <label class="radio-label">
                <input type="radio" name="区分" value="企業" required />
                <span class="radio-custom"></span>
                企業
              </label>
              <label class="radio-label">
                <input type="radio" name="区分" value="団体" required />
                <span class="radio-custom"></span>
                団体（サークル・部活など）
              </label>
            </div>
          </fieldset>

          <!-- ご希望サービス -->
          <fieldset class="form-fieldset">
            <legend class="form-legend">
              ご希望・ご興味のあるサービス <span class="required">必須</span>
            </legend>
            <div class="checkbox-group">
              <label class="checkbox-label">
                <input type="checkbox" name="サービス" value="広告掲載" />
                <span class="checkbox-custom"></span>
                広告掲載
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="サービス" value="新歓映画館企画" />
                <span class="checkbox-custom"></span>
                新歓映画館企画
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="サービス" value="大学祭プラットフォーム" />
                <span class="checkbox-custom"></span>
                大学祭プラットフォーム
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="サービス" value="新歓プラットフォーム" />
                <span class="checkbox-custom"></span>
                新歓プラットフォーム
              </label>
            </div>
          </fieldset>

          <!-- 基本情報 -->
          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="org">
                会社名・団体名 <span class="required">必須</span>
              </label>
              <input
                type="text"
                id="org"
                name="会社名・団体名"
                class="form-input"
                placeholder="例：株式会社〇〇 / △△サークル"
                required
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="name">
                ご担当者名 <span class="required">必須</span>
              </label>
              <input
                type="text"
                id="name"
                name="担当者名"
                class="form-input"
                placeholder="例：山田 太郎"
                required
              />
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label class="form-label" for="email">
                メールアドレス <span class="required">必須</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                class="form-input"
                placeholder="例：info@example.com"
                required
              />
            </div>
            <div class="form-group">
              <label class="form-label" for="tel">
                電話番号 <span class="optional">任意</span>
              </label>
              <input
                type="tel"
                id="tel"
                name="電話番号"
                class="form-input"
                placeholder="例：090-1234-5678"
              />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="message">
              お問い合わせ内容 <span class="optional">任意</span>
            </label>
            <textarea
              id="message"
              name="お問い合わせ内容"
              class="form-input form-textarea"
              placeholder="ご質問・ご要望などをご自由にお書きください"
              rows="6"
            ></textarea>
          </div>

          <!-- 送信ボタン -->
          <div class="form-submit">
            <button type="submit" class="btn btn--gold submit-btn" id="submit-btn">
              送信する
            </button>
            <p class="form-note">
              送信後、担当者より2〜3営業日以内にご連絡いたします。
            </p>
          </div>
        </form>

        <!-- 送信完了メッセージ -->
        <div class="success-message" id="success-msg" style="display:none">
          <div class="success-icon">✓</div>
          <h2>お問い合わせを受け付けました</h2>
          <p>担当者より2〜3営業日以内にご連絡いたします。<br>しばらくお待ちください。</p>
          <a href="/" class="btn btn--outline" style="margin-top:24px">トップに戻る</a>
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
  /* ===== ヒーロー ===== */
  .page-hero {
    padding: 160px 0 80px;
    background: linear-gradient(150deg, #0a0a0a 0%, #110820 100%);
    position: relative;
    overflow: hidden;
  }
  .film-strip--bottom { position: absolute; bottom: 0; left: 0; right: 0; }
  .page-hero-inner { position: relative; z-index: 1; }
  .page-hero-title { font-size: clamp(36px, 6vw, 64px); font-weight: 900; color: #fff; margin-bottom: 12px; }
  .page-hero-sub { font-size: 15px; color: rgba(255,255,255,0.45); }

  /* ===== レイアウト ===== */
  .contact-wrap {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 48px;
    align-items: start;
  }

  /* ===== サイドバー ===== */
  .aside-card {
    background: #fff;
    border-radius: 12px;
    padding: 28px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    margin-bottom: 16px;
  }
  .aside-card--dark {
    background: #0f0f0f;
  }
  .aside-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--purple);
    margin-bottom: 20px;
  }
  .aside-label--gold { color: rgba(255,180,0,0.7); }
  .aside-services { list-style: none; display: flex; flex-direction: column; gap: 20px; }
  .aside-services li { display: flex; gap: 14px; align-items: flex-start; }
  .aside-icon { font-size: 22px; flex-shrink: 0; margin-top: 2px; }
  .aside-services strong { display: block; font-size: 14px; font-weight: 700; color: var(--text-dark); margin-bottom: 4px; }
  .aside-services p { font-size: 12px; color: #888; line-height: 1.6; margin: 0; }
  .aside-email {
    font-size: 13px;
    color: rgba(255,180,0,0.85);
    word-break: break-all;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* ===== フォーム ===== */
  .form-wrap {
    background: #fff;
    border-radius: 16px;
    padding: 48px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.06);
  }
  .form-fieldset {
    border: none;
    margin: 0 0 32px;
    padding: 0;
  }
  .form-legend {
    font-size: 14px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .required {
    font-size: 10px;
    font-weight: 700;
    color: #e03;
    background: rgba(238,0,51,0.08);
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 1px;
  }
  .optional {
    font-size: 10px;
    font-weight: 700;
    color: #999;
    background: #f0f0f0;
    padding: 2px 8px;
    border-radius: 4px;
    letter-spacing: 1px;
  }

  /* ラジオ */
  .radio-group { display: flex; gap: 20px; flex-wrap: wrap; }
  .radio-label {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    font-size: 15px;
    color: var(--text-dark);
    padding: 12px 20px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    transition: border-color 0.15s, background 0.15s;
  }
  .radio-label:has(input:checked) {
    border-color: var(--purple);
    background: rgba(74,40,180,0.04);
  }
  .radio-label input[type="radio"] { display: none; }
  .radio-custom {
    width: 18px;
    height: 18px;
    border: 2px solid #ccc;
    border-radius: 50%;
    flex-shrink: 0;
    position: relative;
    transition: border-color 0.15s;
  }
  .radio-label:has(input:checked) .radio-custom {
    border-color: var(--purple);
  }
  .radio-label:has(input:checked) .radio-custom::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--purple);
  }

  /* チェックボックス */
  .checkbox-group {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
    font-size: 14px;
    color: var(--text-dark);
    padding: 12px 16px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    transition: border-color 0.15s, background 0.15s;
  }
  .checkbox-label:has(input:checked) {
    border-color: var(--gold);
    background: rgba(255,180,0,0.05);
  }
  .checkbox-label input[type="checkbox"] { display: none; }
  .checkbox-custom {
    width: 18px;
    height: 18px;
    border: 2px solid #ccc;
    border-radius: 4px;
    flex-shrink: 0;
    position: relative;
    transition: border-color 0.15s, background 0.15s;
  }
  .checkbox-label:has(input:checked) .checkbox-custom {
    border-color: var(--gold);
    background: var(--gold);
  }
  .checkbox-label:has(input:checked) .checkbox-custom::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 5px;
    width: 5px;
    height: 9px;
    border: 2px solid #0a0a0a;
    border-top: none;
    border-left: none;
    transform: rotate(45deg);
  }

  /* インプット */
  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }
  .form-group { display: flex; flex-direction: column; margin-bottom: 20px; }
  .form-row .form-group { margin-bottom: 0; }
  .form-label {
    font-size: 13px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .form-input {
    padding: 13px 16px;
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    font-size: 15px;
    color: var(--text-dark);
    font-family: inherit;
    background: #fafafa;
    transition: border-color 0.15s, box-shadow 0.15s;
    outline: none;
    width: 100%;
  }
  .form-input:focus {
    border-color: var(--purple);
    box-shadow: 0 0 0 3px rgba(74,40,180,0.08);
    background: #fff;
  }
  .form-input::placeholder { color: #bbb; }
  .form-textarea { resize: vertical; min-height: 140px; line-height: 1.7; }

  /* 送信 */
  .form-submit { margin-top: 8px; }
  .submit-btn {
    font-size: 16px;
    padding: 17px 56px;
    width: 100%;
    justify-content: center;
    border-radius: 8px;
    transition: all 0.2s;
  }
  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none !important;
  }
  .form-note {
    margin-top: 14px;
    font-size: 12px;
    color: #999;
    text-align: center;
    line-height: 1.8;
  }

  /* 送信完了 */
  .success-message {
    text-align: center;
    padding: 64px 32px;
  }
  .success-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(74,40,180,0.1);
    color: var(--purple);
    font-size: 28px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 24px;
  }
  .success-message h2 {
    font-size: 22px;
    font-weight: 700;
    color: var(--text-dark);
    margin-bottom: 12px;
  }
  .success-message p {
    font-size: 15px;
    color: #666;
    line-height: 1.9;
  }

  /* レスポンシブ */
  @media (max-width: 900px) {
    .contact-wrap { grid-template-columns: 1fr; }
    .aside-card { margin-bottom: 8px; }
    .form-wrap { padding: 32px 24px; }
  }
  @media (max-width: 600px) {
    .form-row { grid-template-columns: 1fr; }
    .checkbox-group { grid-template-columns: 1fr; }
    .radio-group { flex-direction: column; gap: 10px; }
    .submit-btn { padding: 16px 32px; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('success-msg') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // チェックボックス必須バリデーション
    const checked = form.querySelectorAll('input[name="サービス"]:checked');
    if (checked.length === 0) {
      alert('ご希望のサービスを1つ以上選択してください。');
      return;
    }

    btn.disabled = true;
    btn.textContent = '送信中...';

    const data = new FormData(form);

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.style.display = 'none';
        successMsg.style.display = 'block';
      } else {
        throw new Error('送信に失敗しました');
      }
    } catch {
      alert('送信中にエラーが発生しました。お手数ですがメールでお問い合わせください。');
      btn.disabled = false;
      btn.textContent = '送信する';
    }
  });
</script>
