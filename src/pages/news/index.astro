---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('news');
const posts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryColors: Record<string, string> = {
  '新歓': '#4a28b4',
  '学祭': '#b47800',
  '協賛': '#1a7a4a',
  '就活': '#1a4a7a',
};
---

<Layout
  title="News | Strategy&"
  description="Strategy&のニュースリリース・活動報告一覧"
>
  <section class="page-hero">
    <div class="film-strip"></div>
    <div class="container page-hero-inner">
      <p class="section-label">News</p>
      <h1 class="page-hero-title">ニュース</h1>
      <p class="page-hero-sub">リリース・活動報告 — {posts.length}件</p>
    </div>
  </section>

  <section class="section section--light">
    <div class="container">

      <!-- 最新記事（大きめ表示） -->
      {posts.length > 0 && (() => {
        const featured = posts[0];
        const color = categoryColors[featured.data.category] ?? '#555';
        return (
          <a href={`/news/${featured.id.replace(/\.md$/, '')}`} class="featured-post">
            {featured.data.coverImage ? (
              <div class="featured-post-image">
                <img src={featured.data.coverImage} alt={featured.data.title} loading="lazy" />
              </div>
            ) : (
              <div class="featured-post-image featured-post-image--placeholder">
                <span>Strategy&</span>
              </div>
            )}
            <div class="featured-post-body">
              <div class="news-meta">
                <time class="news-date">{featured.data.date.replace(/-/g, '.')}</time>
                <span class="news-category" style={`color:${color}; background:${color}18`}>
                  {featured.data.category}
                </span>
                <span class="featured-badge">最新</span>
              </div>
              <h2 class="featured-post-title">{featured.data.title}</h2>
              <p class="featured-post-excerpt">{featured.data.excerpt}</p>
              <span class="news-read-more">続きを読む →</span>
            </div>
          </a>
        );
      })()}

      <!-- 残りの記事一覧 -->
      <div class="news-grid">
        {posts.slice(1).map(post => {
          const color = categoryColors[post.data.category] ?? '#555';
          return (
            <a href={`/news/${post.id.replace(/\.md$/, '')}`} class="news-card">
              {post.data.coverImage ? (
                <div class="news-card-image">
                  <img src={post.data.coverImage} alt={post.data.title} loading="lazy" />
                </div>
              ) : (
                <div class="news-card-image news-card-image--placeholder">
                  <span>{post.data.category}</span>
                </div>
              )}
              <div class="news-card-body">
                <div class="news-meta">
                  <time class="news-date">{post.data.date.replace(/-/g, '.')}</time>
                  <span class="news-category" style={`color:${color}; background:${color}18`}>
                    {post.data.category}
                  </span>
                </div>
                <h2 class="news-card-title">{post.data.title}</h2>
                <p class="news-card-excerpt">{post.data.excerpt}</p>
              </div>
            </a>
          );
        })}
      </div>

    </div>
  </section>
</Layout>

<style>
  .page-hero {
    padding: 160px 0 80px;
    background: linear-gradient(150deg, #0a0a0a 0%, #110820 100%);
    position: relative;
    overflow: hidden;
  }
  .page-hero-inner { position: relative; z-index: 1; }
  .page-hero-title { font-size: clamp(36px, 6vw, 64px); font-weight: 900; color: #fff; margin-bottom: 12px; }
  .page-hero-sub { font-size: 13px; color: rgba(255,255,255,0.35); letter-spacing: 3px; }

  /* ===== 最新記事（featured） ===== */
  .featured-post {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 48px;
    box-shadow: 0 8px 40px rgba(0,0,0,0.1);
    transition: box-shadow 0.2s, transform 0.2s;
    background: #fff;
  }
  .featured-post:hover {
    box-shadow: 0 16px 56px rgba(0,0,0,0.15);
    transform: translateY(-2px);
  }
  .featured-post-image {
    aspect-ratio: 4/3;
    overflow: hidden;
  }
  .featured-post-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .featured-post:hover .featured-post-image img { transform: scale(1.03); }
  .featured-post-image--placeholder {
    background: linear-gradient(135deg, #110820, #1a0a2e);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .featured-post-image--placeholder span {
    font-size: 28px;
    font-weight: 900;
    color: rgba(255,180,0,0.4);
  }
  .featured-post-body {
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .featured-badge {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--gold);
    background: rgba(255,180,0,0.12);
    padding: 2px 10px;
    border-radius: 20px;
  }
  .featured-post-title {
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.4;
    margin: 16px 0 12px;
  }
  .featured-post-excerpt {
    font-size: 14px;
    color: var(--text-mid);
    line-height: 1.8;
    margin-bottom: 20px;
  }

  /* ===== 記事グリッド ===== */
  .news-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .news-card {
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    transition: box-shadow 0.2s, transform 0.2s;
    display: flex;
    flex-direction: column;
  }
  .news-card:hover {
    box-shadow: 0 10px 36px rgba(0,0,0,0.12);
    transform: translateY(-3px);
  }
  .news-card-image {
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .news-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  .news-card:hover .news-card-image img { transform: scale(1.05); }
  .news-card-image--placeholder {
    background: linear-gradient(135deg, #0f0f0f, #1a1a2e);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .news-card-image--placeholder span {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    color: rgba(255,180,0,0.4);
    text-transform: uppercase;
  }
  .news-card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; }
  .news-card-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-dark);
    line-height: 1.5;
    margin: 10px 0 8px;
    flex: 1;
  }
  .news-card-excerpt {
    font-size: 13px;
    color: #888;
    line-height: 1.7;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ===== 共通 ===== */
  .news-meta { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .news-date { font-size: 12px; color: #aaa; }
  .news-category {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1px;
    padding: 2px 8px;
    border-radius: 20px;
  }
  .news-read-more { font-size: 13px; color: var(--purple); font-weight: 600; }

  /* ===== レスポンシブ ===== */
  @media (max-width: 900px) {
    .news-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .featured-post { grid-template-columns: 1fr; }
    .featured-post-body { padding: 24px; }
    .news-grid { grid-template-columns: 1fr; }
  }
</style>
