---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('gakusai'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Layout
  title="大学スタイル | 学祭メディア"
  description="全国の大学祭を取材・発信する学生メディア。学祭運営者のリアルな声や、学祭カレンダー、デジタルプラットフォーム情報をお届けします。"
>

  <!-- ===== HERO ===== -->
  <section class="ds-hero">
    <div class="container ds-hero-inner">
      <p class="ds-eyebrow">大学スタイル — 学祭メディア</p>
      <h1 class="ds-hero-title">
        全国の学祭を、<br>
        <em>もっと身近に。</em>
      </h1>
      <p class="ds-hero-lead">
        学祭運営者のリアルな声を届け、<br>
        大学祭をもっと良くするための情報プラットフォーム。
      </p>
      <div class="ds-hero-ctas">
        <a href="/festivals/calendar" class="btn btn--gold">学祭カレンダーを見る</a>
        <a href="/festivals/media" class="btn btn--outline">取材記事を読む</a>
      </div>
    </div>
    <div class="film-strip film-strip--bottom"></div>
  </section>

  <!-- ===== NUMBERS ===== -->
  <section class="section section--dark">
    <div class="container">
      <p class="section-label">実績</p>
      <div class="section-divider"></div>
      <div class="ds-numbers">
        <div class="ds-num-item">
          <strong>5+</strong>
          <span>取材大学数</span>
        </div>
        <div class="ds-num-item">
          <strong>5</strong>
          <span>公開記事数</span>
        </div>
        <div class="ds-num-item">
          <strong>32+</strong>
          <span>掲載学祭数</span>
        </div>
        <div class="ds-num-item">
          <strong>Instagram</strong>
          <span><a href="https://www.instagram.com/gakusei_style/" target="_blank" rel="noopener" class="ds-ig-link">@gakusei_style</a></span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 3メニュー ===== -->
  <section class="section section--darker">
    <div class="container">
      <p class="section-label">サービス</p>
      <div class="section-divider"></div>
      <div class="ds-menu-grid">

        <a href="/festivals/calendar" class="ds-menu-card">
          <div class="ds-menu-icon">🗓️</div>
          <h3>学祭カレンダー</h3>
          <p>全国の大学祭の開催日程を月別・地域別に一覧。開催申請フォームで情報追加も可能。</p>
          <span class="ds-menu-link">カレンダーを見る →</span>
        </a>

        <a href="/festivals/platform" class="ds-menu-card">
          <div class="ds-menu-icon">🏟️</div>
          <h3>学祭プラットフォーム</h3>
          <p>学祭運営のデジタル化を支援。導入実績や、運営交流会の情報はこちら。</p>
          <span class="ds-menu-link">詳細を見る →</span>
        </a>

        <a href="/festivals/media" class="ds-menu-card">
          <div class="ds-menu-icon">📰</div>
          <h3>取材記事</h3>
          <p>全国の学祭運営者へのインタビューや、学祭データ分析記事を公開中。</p>
          <span class="ds-menu-link">記事を読む →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- ===== 最新記事 ===== -->
  <section class="section section--dark">
    <div class="container">
      <p class="section-label">最新記事</p>
      <div class="section-divider"></div>
      <h2 class="section-title">取材・分析レポート</h2>
      <div class="ds-articles-grid">
        {articles.map(post => (
          <a href={`/festivals/media/${post.id.replace(/\.md$/, '')}`} class="ds-article-card">
            {post.data.coverImage && (
              <div class="ds-article-thumb">
                <img src={post.data.coverImage} alt={post.data.title} loading="lazy" />
              </div>
            )}
            <div class="ds-article-body">
              {post.data.festivalName && (
                <span class="ds-article-tag">{post.data.festivalName}</span>
              )}
              <h3>{post.data.title}</h3>
              <p class="ds-article-excerpt">{post.data.excerpt}</p>
              <time class="ds-article-date">{post.data.date}</time>
            </div>
          </a>
        ))}
      </div>
      <div style="text-align:center; margin-top:48px">
        <a href="/festivals/media" class="btn btn--outline">すべての記事を見る</a>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="section" style="background: linear-gradient(160deg, #0a1428 0%, #110820 100%); text-align:center">
    <div class="container--narrow">
      <p class="section-label" style="text-align:center">Contact</p>
      <div class="section-divider" style="margin:0 auto 28px"></div>
      <h2 class="section-title">学祭を一緒に盛り上げませんか？</h2>
      <p class="section-lead" style="margin:0 auto 40px; text-align:center">
        取材依頼・掲載申請・プラットフォーム導入のご相談は<br>お気軽にどうぞ。
      </p>
      <a href="/contact" class="btn btn--gold" style="font-size:16px; padding:18px 48px">
        お問い合わせ
      </a>
    </div>
  </section>

</Layout>

<style>
  .ds-hero {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    background: linear-gradient(150deg, #0a0a0a 0%, #0a1a10 55%, #0a1428 100%);
    overflow: hidden;
    padding: 160px 0 80px;
  }
  .ds-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 60% 50%, rgba(0,200,80,0.05) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 20% 80%, rgba(74,40,180,0.08) 0%, transparent 60%);
    pointer-events: none;
  }
  .ds-hero-inner { position: relative; z-index: 1; }
  .ds-eyebrow {
    font-size: 12px;
    letter-spacing: 4px;
    color: rgba(0,220,100,0.7);
    text-transform: uppercase;
    margin-bottom: 28px;
  }
  .ds-hero-title {
    font-size: clamp(32px, 5vw, 60px);
    font-weight: 900;
    line-height: 1.2;
    color: #fff;
    margin-bottom: 24px;
  }
  .ds-hero-title em { font-style: normal; color: #00dc64; }
  .ds-hero-lead {
    font-size: clamp(14px, 2vw, 17px);
    color: rgba(255,255,255,0.55);
    line-height: 2;
    margin-bottom: 48px;
  }
  .ds-hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }

  /* ===== NUMBERS ===== */
  .ds-numbers {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 48px;
  }
  .ds-num-item {
    background: var(--bg-card);
    padding: 40px 24px;
    text-align: center;
  }
  .ds-num-item strong {
    display: block;
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 900;
    color: #00dc64;
    line-height: 1;
    margin-bottom: 12px;
  }
  .ds-num-item span {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
  }
  .ds-ig-link {
    color: #00dc64;
    text-decoration: none;
  }
  .ds-ig-link:hover { text-decoration: underline; }

  /* ===== 3メニュー ===== */
  .ds-menu-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 56px;
  }
  .ds-menu-card {
    background: var(--bg-card);
    padding: 44px 32px;
    display: block;
    transition: background var(--transition);
    border-top: 2px solid rgba(255,255,255,0.04);
    text-decoration: none;
  }
  .ds-menu-card:hover { background: #1a1a1a; }
  .ds-menu-icon { font-size: 36px; margin-bottom: 20px; }
  .ds-menu-card h3 {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
  }
  .ds-menu-card p {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
    line-height: 1.8;
    margin-bottom: 20px;
  }
  .ds-menu-link {
    font-size: 13px;
    color: #00dc64;
    font-weight: 600;
  }

  /* ===== 最新記事 ===== */
  .ds-articles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 48px;
  }
  .ds-article-card {
    background: var(--bg-card);
    display: block;
    text-decoration: none;
    transition: background var(--transition);
  }
  .ds-article-card:hover { background: #1a1a1a; }
  .ds-article-thumb {
    aspect-ratio: 16/9;
    overflow: hidden;
  }
  .ds-article-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .ds-article-card:hover .ds-article-thumb img { transform: scale(1.04); }
  .ds-article-body { padding: 28px 24px; }
  .ds-article-tag {
    display: inline-block;
    font-size: 11px;
    color: #00dc64;
    border: 1px solid rgba(0,220,100,0.3);
    padding: 2px 10px;
    border-radius: 20px;
    margin-bottom: 12px;
  }
  .ds-article-card h3 {
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    line-height: 1.5;
    margin-bottom: 10px;
  }
  .ds-article-excerpt {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .ds-article-date {
    font-size: 12px;
    color: rgba(255,255,255,0.25);
  }

  @media (max-width: 768px) {
    .ds-numbers { grid-template-columns: repeat(2, 1fr); }
    .ds-menu-grid { grid-template-columns: 1fr; }
    .ds-articles-grid { grid-template-columns: 1fr; }
  }
</style>
