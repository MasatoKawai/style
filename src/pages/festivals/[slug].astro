---
import Layout from '../../layouts/Layout.astro';
import { festivals } from '../../data/festivals';

export function getStaticPaths() {
  return festivals
    .filter(f => f.slug)
    .map(f => ({ params: { slug: f.slug }, props: { festival: f } }));
}

const { festival: f } = Astro.props;

const monthNames: Record<number, string> = {
  5:'5月', 6:'6月', 10:'10月', 11:'11月',
  1:'1月', 2:'2月', 3:'3月', 4:'4月',
  7:'7月', 8:'8月', 9:'9月', 12:'12月',
};

const sponsorLabel = {
  open: '協賛・広告 募集中',
  closed: '募集終了',
  unknown: '詳細未確認',
}[f.sponsorStatus ?? 'unknown'];

const sponsorColor = {
  open: '#00dc64',
  closed: 'rgba(255,255,255,0.3)',
  unknown: 'rgba(255,180,0,0.7)',
}[f.sponsorStatus ?? 'unknown'];
---

<Layout
  title={`${f.festivalName}（${f.university}） 2026 | 大学スタイル`}
  description={f.description ?? `${f.university}の学園祭「${f.festivalName}」の2026年開催情報。日程・来場者数・協賛募集状況をまとめています。`}
>

  <!-- ===== パンくず ===== -->
  <nav class="breadcrumb">
    <div class="container">
      <a href="/festivals/calendar">学祭カレンダー</a>
      <span class="sep">›</span>
      <span>{f.festivalName}</span>
    </div>
  </nav>

  <!-- ===== ヒーロー ===== -->
  <section class="festival-hero">
    <div class="container">
      <div class="hero-meta">
        <span class="hero-month">{monthNames[f.month]}</span>
        <span class="hero-sponsor-badge" style={`color:${sponsorColor};border-color:${sponsorColor}33;background:${sponsorColor}11`}>
          {sponsorLabel}
        </span>
      </div>
      <h1 class="hero-title">{f.festivalName}</h1>
      <p class="hero-sub">
        {f.university}
        {f.history && <span class="hero-history"> · {f.history}</span>}
        <span class="hero-pref"> · {f.prefecture}</span>
      </p>
      {f.reach && (
        <p class="hero-reach">来場者数 <strong>{f.reach}</strong></p>
      )}
    </div>
  </section>

  <!-- ===== メインコンテンツ ===== -->
  <section class="section section--dark">
    <div class="container">
      <div class="detail-layout">

        <!-- 左カラム -->
        <div class="detail-main">

          <!-- 基本情報 -->
          <div class="info-card">
            <h2 class="card-title">基本情報</h2>
            <dl class="info-list">
              <div class="info-row">
                <dt>日程</dt>
                <dd class="date-text">{f.dateText}</dd>
              </div>
              {f.venue && (
                <div class="info-row">
                  <dt>会場</dt>
                  <dd>{f.venue}</dd>
                </div>
              )}
              <div class="info-row">
                <dt>場所</dt>
                <dd>{f.prefecture}</dd>
              </div>
              {f.reach && (
                <div class="info-row">
                  <dt>来場者数</dt>
                  <dd>{f.reach}</dd>
                </div>
              )}
              {f.studentCount && (
                <div class="info-row">
                  <dt>在籍学生数</dt>
                  <dd>{f.studentCount}</dd>
                </div>
              )}
              {f.url && (
                <div class="info-row">
                  <dt>公式サイト</dt>
                  <dd><a href={f.url} target="_blank" rel="noopener" class="ext-link">{f.url.replace(/^https?:\/\//, '')} →</a></dd>
                </div>
              )}
            </dl>
          </div>

          <!-- 学祭について -->
          {(f.description || f.highlights) && (
            <div class="info-card">
              <h2 class="card-title">学祭について</h2>
              {f.description && <p class="description-text">{f.description}</p>}
              {f.highlights && f.highlights.length > 0 && (
                <div class="highlights">
                  <p class="highlights-label">見どころ</p>
                  <ul class="highlights-list">
                    {f.highlights.map(h => <li>{h}</li>)}
                  </ul>
                </div>
              )}
            </div>
          )}

          <!-- SNS -->
          {(f.instagramUrl || f.xUrl) && (
            <div class="info-card">
              <h2 class="card-title">公式SNS</h2>
              <div class="sns-links">
                {f.instagramUrl && (
                  <a href={f.instagramUrl} target="_blank" rel="noopener" class="sns-btn sns-btn--ig">
                    Instagram
                  </a>
                )}
                {f.xUrl && (
                  <a href={f.xUrl} target="_blank" rel="noopener" class="sns-btn sns-btn--x">
                    X (Twitter)
                  </a>
                )}
              </div>
            </div>
          )}

        </div>

        <!-- 右カラム：企業向けCTA -->
        <aside class="detail-side">

          <div class="sponsor-card">
            <p class="sponsor-card-eyebrow">FOR COMPANIES</p>
            <h3 class="sponsor-card-title">この学祭に<br>広告を出しませんか？</h3>

            <div class="sponsor-status">
              <span class="status-dot" style={`background:${sponsorColor}`}></span>
              <span style={`color:${sponsorColor}`}>{sponsorLabel}</span>
            </div>

            {f.reach && (
              <div class="sponsor-reach">
                <p class="sponsor-reach-num">{f.reach}</p>
                <p class="sponsor-reach-label">の来場者にリーチ</p>
              </div>
            )}
            {f.studentCount && (
              <p class="sponsor-student">在籍学生数 {f.studentCount}</p>
            )}

            {f.pastSponsors && (
              <div class="past-sponsors">
                <p class="past-sponsors-label">過去スポンサー例</p>
                <p class="past-sponsors-text">{f.pastSponsors}</p>
              </div>
            )}

            <a href="/contact" class="btn btn--gold sponsor-cta-full">
              スポンサー・広告のご相談
            </a>
            <p class="sponsor-note">無料相談 · 返信は1営業日以内</p>
          </div>

          <!-- カレンダーへ戻る -->
          <a href="/festivals/calendar" class="back-link">← 学祭カレンダーに戻る</a>

        </aside>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ===== パンくず ===== */
  .breadcrumb {
    background: #0d0d0d;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 14px 0;
    padding-top: calc(68px + 14px); /* fixed header 68px 分オフセット */
  }
  .breadcrumb .container {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
  }
  .breadcrumb a { color: #00dc64; text-decoration: none; }
  .breadcrumb a:hover { text-decoration: underline; }
  .sep { color: rgba(255,255,255,0.2); }
  .breadcrumb span:last-child { color: rgba(255,255,255,0.5); }

  /* ===== ヒーロー ===== */
  .festival-hero {
    padding: 64px 0 52px;
    background: linear-gradient(150deg, #0a0a0a 0%, #0a1a10 100%);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .hero-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }
  .hero-month {
    font-size: 11px;
    font-weight: 700;
    color: #00dc64;
    letter-spacing: 1px;
    border: 1px solid rgba(0,220,100,0.3);
    padding: 3px 12px;
    border-radius: 20px;
  }
  .hero-sponsor-badge {
    font-size: 11px;
    font-weight: 700;
    padding: 3px 12px;
    border-radius: 20px;
    border: 1px solid;
  }
  .hero-title {
    font-size: clamp(32px, 6vw, 60px);
    font-weight: 900;
    color: #fff;
    line-height: 1.2;
    margin-bottom: 12px;
  }
  .hero-sub {
    font-size: 15px;
    color: rgba(255,255,255,0.5);
    margin-bottom: 16px;
  }
  .hero-history { color: rgba(255,255,255,0.35); }
  .hero-pref { color: rgba(255,255,255,0.35); }
  .hero-reach {
    font-size: 14px;
    color: rgba(0,220,100,0.7);
  }
  .hero-reach strong { color: #00dc64; font-size: 18px; }

  /* ===== レイアウト ===== */
  .detail-layout {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 32px;
    align-items: start;
  }
  .detail-main { display: flex; flex-direction: column; gap: 24px; }

  /* ===== 情報カード ===== */
  .info-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 28px 32px;
  }
  .card-title {
    font-size: 13px;
    font-weight: 700;
    color: rgba(0,220,100,0.7);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 20px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .info-list { display: flex; flex-direction: column; gap: 14px; }
  .info-row { display: grid; grid-template-columns: 100px 1fr; gap: 12px; align-items: baseline; }
  .info-row dt {
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 0.5px;
  }
  .info-row dd {
    font-size: 14px;
    color: rgba(255,255,255,0.85);
  }
  .date-text { color: rgba(255,180,0,0.9); font-weight: 600; }
  .ext-link { color: #00dc64; text-decoration: none; font-size: 13px; }
  .ext-link:hover { text-decoration: underline; }

  .description-text {
    font-size: 14px;
    color: rgba(255,255,255,0.65);
    line-height: 1.9;
    margin-bottom: 20px;
  }
  .highlights-label {
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 1px;
    margin-bottom: 10px;
  }
  .highlights-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .highlights-list li {
    font-size: 14px;
    color: rgba(255,255,255,0.7);
    padding-left: 18px;
    position: relative;
  }
  .highlights-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: #00dc64;
    font-size: 11px;
  }

  .sns-links { display: flex; gap: 12px; flex-wrap: wrap; }
  .sns-btn {
    padding: 10px 24px;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .sns-btn:hover { opacity: 0.8; }
  .sns-btn--ig { background: linear-gradient(135deg, #833ab4, #fd1d1d, #fcb045); color: #fff; }
  .sns-btn--x { background: #000; border: 1px solid rgba(255,255,255,0.2); color: #fff; }

  /* ===== 右カラム: スポンサーCTA ===== */
  .detail-side { display: flex; flex-direction: column; gap: 16px; }
  .sponsor-card {
    background: #0d0d0d;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .sponsor-card-eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 3px;
    color: rgba(255,180,0,0.6);
  }
  .sponsor-card-title {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    line-height: 1.4;
  }
  .sponsor-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
  }
  .status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .sponsor-reach {
    background: rgba(0,220,100,0.06);
    border: 1px solid rgba(0,220,100,0.15);
    border-radius: 8px;
    padding: 14px 16px;
    text-align: center;
  }
  .sponsor-reach-num {
    font-size: 24px;
    font-weight: 900;
    color: #00dc64;
    line-height: 1;
    margin-bottom: 4px;
  }
  .sponsor-reach-label {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
  }
  .sponsor-student {
    font-size: 12px;
    color: rgba(255,255,255,0.35);
    text-align: center;
  }
  .past-sponsors {
    padding: 14px 16px;
    background: rgba(255,255,255,0.02);
    border-radius: 8px;
  }
  .past-sponsors-label {
    font-size: 11px;
    color: rgba(255,255,255,0.3);
    margin-bottom: 6px;
    letter-spacing: 1px;
  }
  .past-sponsors-text {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    line-height: 1.6;
  }
  .sponsor-cta-full {
    display: block;
    text-align: center;
    padding: 14px;
    font-size: 14px;
    font-weight: 700;
  }
  .sponsor-note {
    font-size: 11px;
    color: rgba(255,255,255,0.25);
    text-align: center;
  }

  .back-link {
    display: block;
    text-align: center;
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    text-decoration: none;
    padding: 12px;
  }
  .back-link:hover { color: rgba(255,255,255,0.6); }

  /* ===== レスポンシブ ===== */
  @media (max-width: 860px) {
    .detail-layout {
      grid-template-columns: 1fr;
    }
    .detail-side {
      order: -1;
    }
  }
  @media (max-width: 480px) {
    .info-card { padding: 20px; }
    .info-row { grid-template-columns: 80px 1fr; }
  }
</style>
