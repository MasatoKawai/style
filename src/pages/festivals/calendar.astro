  }

  /* ===== 掲載申請バナー ===== */
  .apply-banner {
    margin: 0;
    padding: 40px 48px;
    background: rgba(0,220,100,0.06);
    border: 1px solid rgba(0,220,100,0.2);
    display: flex;
    justify-content: space-between;
    align-items: center;
