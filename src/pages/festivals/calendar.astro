---
import Layout from '../../layouts/Layout.astro';
import { festivals, prefectures, months } from '../../data/festivals';

const monthNames: Record<number, string> = {
  1:'1月', 2:'2月', 3:'3月', 4:'4月', 5:'5月', 6:'6月',
  7:'7月', 8:'8月', 9:'9月', 10:'10月', 11:'11月', 12:'12月'
};

// カウントダウン用（startDateあり）
const datedFestivals = festivals.filter(f => f.startDate);

// 月ごとにグループ化
const festivalsByMonth = months.map(m => ({
  month: m,
  label: monthNames[m],
  items: festivals.filter(f => f.month === m),
}));

const totalCount = festivals.length;
---

<Layout
  title="学祭カレンダー 2026 | 大学スタイル"
  description="全国の大学祭・学園祭の開催日程を月別・地域別に一覧。2026年の学祭情報とスポンサー募集状況をまとめています。"
>

  <!-- ===== ページヒーロー ===== -->
  <section class="page-hero">
    <div class="film-strip"></div>
    <div class="container page-hero-inner">
      <p class="section-label" style="color:rgba(0,220,100,0.8)">大学スタイル</p>
      <h1 class="page-hero-title">学祭カレンダー <span class="year">2026</span></h1>
      <p class="page-hero-sub">全国の大学祭・学園祭の開催日程一覧</p>
    </div>
    <div class="film-strip film-strip--bottom"></div>
  </section>

  <!-- ===== 直近カウントダウン ===== -->
  <section class="countdown-section">
    <div class="container">
      <p class="countdown-eyebrow">直近の開催予定</p>
      <div class="countdown-layout" id="countdown-layout">
        <!-- JS で描画 -->
        <div class="cd-featured-skeleton"></div>
        <div class="cd-list-skeleton">
          <div class="cd-list-item-skeleton"></div>
          <div class="cd-list-item-skeleton"></div>
          <div class="cd-list-item-skeleton"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- JSON データをクライアントに渡す -->
  <script id="festival-data" type="application/json" set:html={JSON.stringify(datedFestivals)}></script>

  <!-- ===== フィルター + 月別一覧 ===== -->
  <section class="section section--dark">
    <div class="container">

      <!-- フィルターUI -->
      <div class="filter-bar">
        <div class="filter-group">
          <label class="filter-label">月</label>
          <div class="filter-chips" id="month-filters">
            <button class="chip chip--active" data-filter="month" data-value="all">すべて</button>
            {months.map(m => (
              <button class="chip" data-filter="month" data-value={m}>{monthNames[m]}</button>
            ))}
          </div>
        </div>
        <div class="filter-group">
          <label class="filter-label">地域</label>
          <div class="filter-chips" id="pref-filters">
            <button class="chip chip--active" data-filter="pref" data-value="all">すべて</button>
            {prefectures.map(p => (
              <button class="chip" data-filter="pref" data-value={p}>{p}</button>
            ))}
          </div>
        </div>
        <div class="filter-group">
          <label class="filter-label">協賛</label>
          <div class="filter-chips" id="sponsor-filters">
            <button class="chip chip--active" data-filter="sponsor" data-value="all">すべて</button>
            <button class="chip" data-filter="sponsor" data-value="open">募集中のみ</button>
          </div>
        </div>
      </div>

      <!-- 件数 -->
      <p class="result-count"><span id="result-num">{totalCount}</span>件の学祭</p>

      <!-- 月別グループ -->
      <div id="festivals-container">
        {festivalsByMonth.map(({ month, label, items }) => (
          <div class="month-group" data-month={month}>
            <div class="month-header">
              <span class="month-label-lg">{label}</span>
              <span class="month-count">{items.length}件</span>
              <div class="month-line"></div>
            </div>
            <div class="festival-rows">
              {items.map(f => (
                <div
                  class={`festival-row${f.slug ? ' festival-row--linked' : ''}`}
                  data-pref={f.prefecture}
                  data-sponsor={f.sponsorStatus ?? 'unknown'}
                >
                  {/* クリッカブルな場合は <a> をオーバーレイ */}
                  {f.slug && (
                    <a href={`/festivals/${f.slug}`} class="row-overlay" aria-label={`${f.festivalName} 詳細`}></a>
                  )}

                  <div class="row-main">
                    <div class="row-name-wrap">
                      <span class="row-name">{f.festivalName}</span>
                      <span class="row-univ">{f.university}</span>
                    </div>
                    <div class="row-meta">
                      <span class="row-date">{f.dateText}</span>
                      {f.reach && <span class="row-reach">{f.reach}</span>}
                      {f.sponsorStatus === 'open' && (
                        <span class="row-badge row-badge--open">募集中</span>
                      )}
                      {f.sponsorStatus === 'closed' && (
                        <span class="row-badge row-badge--closed">終了</span>
                      )}
                    </div>
                  </div>

                  <div class="row-right">
                    <span class="row-pref">{f.prefecture}</span>
                    {f.slug
                      ? <span class="row-arrow">詳細 →</span>
                      : f.url
                        ? <a href={f.url} target="_blank" rel="noopener" class="row-ext" onClick="event.stopPropagation()">公式 →</a>
                        : null
                    }
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- ===== スポンサー・広告 CTA ===== -->
  <section class="sponsor-section">
    <div class="container">
      <div class="sponsor-inner">
        <div class="sponsor-text">
          <p class="sponsor-eyebrow">FOR COMPANIES</p>
          <h2 class="sponsor-title">大学生へのリーチ、<br>大学祭で一気に。</h2>
          <p class="sponsor-desc">
            新入生・在学生が最も熱量高く集まる大学祭に、企業・サービスを届けます。<br>
            ブース出展・チラシ配布・SNS連携など、大学祭ごとにカスタマイズ可能。
          </p>
          <div class="sponsor-points">
            <div class="sponsor-point">
              <span class="point-icon">🎯</span>
              <div>
                <strong>ターゲット精度が高い</strong>
                <p>大学・学部・入学年度で絞った学生にリーチ</p>
              </div>
            </div>
            <div class="sponsor-point">
              <span class="point-icon">📣</span>
              <div>
                <strong>リアルとSNSの同時拡散</strong>
                <p>会場接触＋デジタルリーチ（学祭アカウント・HP等）</p>
              </div>
            </div>
            <div class="sponsor-point">
              <span class="point-icon">📊</span>
              <div>
                <strong>効果測定まで対応</strong>
                <p>QR経由での流入・エンゲージメント計測をサポート</p>
              </div>
            </div>
          </div>
          <a href="/contact" class="btn btn--gold sponsor-cta-btn">スポンサー・広告のご相談</a>
        </div>
        <div class="sponsor-stats">
          <div class="stat-card">
            <p class="stat-num">{totalCount}<span>件+</span></p>
            <p class="stat-label">掲載大学祭数</p>
          </div>
          <div class="stat-card">
            <p class="stat-num">全国<span>対応</span></p>
            <p class="stat-label">北海道〜九州</p>
          </div>
          <div class="stat-card">
            <p class="stat-num">3<span>件</span></p>
            <p class="stat-label">スポンサー募集中</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 掲載申請バナー ===== -->
  <section class="section section--dark">
    <div class="container">
      <div class="apply-banner">
        <div>
          <h3>あなたの学祭を掲載しませんか？</h3>
          <p>情報の追加・修正はお気軽にご連絡ください。</p>
        </div>
        <a href="/contact" class="btn btn--gold">掲載申請・修正依頼</a>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ===== ヒーロー ===== */
  .page-hero {
    padding: 160px 0 80px;
    background: linear-gradient(150deg, #0a0a0a 0%, #0a1a10 100%);
    position: relative;
    overflow: hidden;
  }
  .film-strip--bottom { position: absolute; bottom: 0; left: 0; right: 0; }
  .page-hero-inner { position: relative; z-index: 1; }
  .page-hero-title {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 900;
    color: #fff;
    margin-bottom: 12px;
  }
  .page-hero-title .year { color: #00dc64; }
  .page-hero-sub {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 3px;
  }

  /* ===== カウントダウン ===== */
  .countdown-section {
    background: #0d0d0d;
    padding: 48px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .countdown-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    color: rgba(0,220,100,0.5);
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  /* スケルトン */
  .countdown-layout { display: grid; grid-template-columns: 1fr 320px; gap: 16px; }
  .cd-featured-skeleton {
    height: 200px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    animation: pulse 1.5s ease-in-out infinite;
  }
  .cd-list-skeleton { display: flex; flex-direction: column; gap: 8px; }
  .cd-list-item-skeleton {
    height: 56px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    animation: pulse 1.5s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100%{opacity:.4} 50%{opacity:.8} }

  /* ===== featured カード (JS生成) ===== */
  .cd-featured {
    border-radius: 16px;
    border: 1px solid rgba(0,220,100,0.2);
    background: rgba(0,220,100,0.05);
    padding: 32px 36px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.15s;
    cursor: pointer;
  }
  .cd-featured:hover { border-color: rgba(0,220,100,0.5); transform: translateY(-2px); }
  .cd-featured--today { background: rgba(0,220,100,0.08); border-color: rgba(0,220,100,0.4); }
  .cd-featured--ongoing { background: rgba(255,180,0,0.06); border-color: rgba(255,180,0,0.25); }

  .cd-feat-top { display: flex; align-items: flex-end; justify-content: space-between; }
  .cd-feat-count {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .cd-feat-num {
    font-size: clamp(64px, 10vw, 96px);
    font-weight: 900;
    color: #00dc64;
    line-height: 1;
    letter-spacing: -4px;
  }
  .cd-featured--ongoing .cd-feat-num { color: #ffb400; }
  .cd-featured--today .cd-feat-num { font-size: 48px; letter-spacing: 0; }
  .cd-feat-unit {
    font-size: 22px;
    font-weight: 700;
    color: rgba(0,220,100,0.6);
    padding-bottom: 10px;
  }
  .cd-featured--ongoing .cd-feat-unit { color: rgba(255,180,0,0.6); }
  .cd-feat-reach {
    text-align: right;
  }
  .cd-feat-reach-num {
    font-size: 24px;
    font-weight: 900;
    color: #fff;
    line-height: 1;
  }
  .cd-feat-reach-label {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 1px;
  }

  .cd-feat-divider {
    height: 1px;
    background: rgba(255,255,255,0.07);
    margin: 4px 0;
  }

  .cd-feat-name {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
  }
  .cd-feat-univ {
    font-size: 14px;
    color: rgba(255,255,255,0.45);
  }
  .cd-feat-date {
    font-size: 13px;
    color: rgba(255,180,0,0.8);
  }
  .cd-feat-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4px;
  }
  .cd-feat-pref {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
  }
  .cd-feat-cta {
    font-size: 12px;
    font-weight: 700;
    color: #00dc64;
  }
  .cd-featured--ongoing .cd-feat-cta { color: #ffb400; }

  /* ===== リスト側 (JS生成) ===== */
  .cd-list { display: flex; flex-direction: column; gap: 8px; }
  .cd-list-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
    cursor: pointer;
  }
  .cd-list-item:hover { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.15); }
  .cd-list-badge {
    font-size: 11px;
    font-weight: 700;
    color: rgba(0,220,100,0.8);
    background: rgba(0,220,100,0.08);
    border: 1px solid rgba(0,220,100,0.2);
    padding: 4px 10px;
    border-radius: 20px;
    white-space: nowrap;
    flex-shrink: 0;
    min-width: 52px;
    text-align: center;
  }
  .cd-list-badge--ongoing { color: rgba(255,180,0,0.8); background: rgba(255,180,0,0.08); border-color: rgba(255,180,0,0.2); }
  .cd-list-info { flex: 1; min-width: 0; }
  .cd-list-name {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cd-list-sub {
    font-size: 11px;
    color: rgba(255,255,255,0.35);
    margin-top: 1px;
  }
  .cd-list-arrow {
    font-size: 12px;
    color: rgba(255,255,255,0.2);
    flex-shrink: 0;
  }

  /* ===== フィルター ===== */
  .filter-bar {
    display: flex;
    gap: 24px;
    margin-bottom: 24px;
    padding: 20px 24px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 4px;
    flex-wrap: wrap;
  }
  .filter-group { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .filter-label {
    font-size: 11px;
    font-weight: 700;
    color: rgba(255,255,255,0.3);
    letter-spacing: 1px;
    white-space: nowrap;
  }
  .filter-chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .chip {
    padding: 5px 14px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.45);
    font-size: 12px;
    cursor: pointer;
    border-radius: 20px;
    transition: all 0.15s;
  }
  .chip:hover { border-color: #00dc64; color: #00dc64; }
  .chip--active { background: #00dc64; border-color: #00dc64; color: #000; font-weight: 700; }

  .result-count {
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    margin-bottom: 32px;
  }
  .result-count span { color: #00dc64; font-weight: 700; }

  /* ===== 月別グループ ===== */
  .month-group { margin-bottom: 40px; }
  .month-group[hidden] { display: none; }

  .month-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 8px;
  }
  .month-label-lg {
    font-size: 13px;
    font-weight: 900;
    color: #00dc64;
    letter-spacing: 1px;
    white-space: nowrap;
  }
  .month-count {
    font-size: 11px;
    color: rgba(255,255,255,0.25);
  }
  .month-line { flex: 1; height: 1px; background: rgba(255,255,255,0.07); }

  /* ===== 学祭行 ===== */
  .festival-rows { display: flex; flex-direction: column; }

  .festival-row {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    position: relative;
    transition: background 0.15s;
  }
  .festival-row:first-child { border-top: 1px solid rgba(255,255,255,0.05); }
  .festival-row[hidden] { display: none; }
  .festival-row--linked { cursor: pointer; }
  .festival-row--linked:hover { background: rgba(255,255,255,0.03); }

  .row-overlay {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .festival-row > * { position: relative; z-index: 1; }

  .row-main {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .row-name-wrap {
    min-width: 0;
    flex-shrink: 0;
    width: 220px;
  }
  .row-name {
    display: block;
    font-size: 15px;
    font-weight: 700;
    color: #fff;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .row-univ {
    display: block;
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    margin-top: 1px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .row-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    flex: 1;
  }
  .row-date {
    font-size: 13px;
    color: rgba(255,180,0,0.8);
    white-space: nowrap;
  }
  .row-reach {
    font-size: 12px;
    color: rgba(0,220,100,0.6);
    font-weight: 600;
    white-space: nowrap;
  }
  .row-badge {
    font-size: 10px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 20px;
    white-space: nowrap;
  }
  .row-badge--open {
    color: #00dc64;
    background: rgba(0,220,100,0.1);
    border: 1px solid rgba(0,220,100,0.25);
  }
  .row-badge--closed {
    color: rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
  }

  .row-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .row-pref {
    font-size: 12px;
    color: rgba(255,255,255,0.25);
  }
  .row-arrow {
    font-size: 12px;
    color: rgba(0,220,100,0.5);
    font-weight: 600;
    white-space: nowrap;
  }
  .festival-row--linked:hover .row-arrow { color: #00dc64; }
  .row-ext {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    text-decoration: none;
    position: relative;
    z-index: 2;
    white-space: nowrap;
  }
  .row-ext:hover { color: rgba(255,255,255,0.6); text-decoration: underline; }

  /* ===== スポンサーCTA ===== */
  .sponsor-section {
    background: #080808;
    padding: 80px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .sponsor-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 64px;
    align-items: center;
  }
  .sponsor-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 3px;
    color: rgba(255,180,0,0.6);
    margin-bottom: 16px;
  }
  .sponsor-title {
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 20px;
  }
  .sponsor-desc {
    font-size: 15px;
    color: rgba(255,255,255,0.5);
    line-height: 1.9;
    margin-bottom: 36px;
  }
  .sponsor-points { display: flex; flex-direction: column; gap: 20px; margin-bottom: 40px; }
  .sponsor-point { display: flex; gap: 16px; align-items: flex-start; }
  .point-icon { font-size: 22px; flex-shrink: 0; margin-top: 2px; }
  .sponsor-point strong { display: block; font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .sponsor-point p { font-size: 13px; color: rgba(255,255,255,0.4); line-height: 1.6; margin: 0; }
  .sponsor-cta-btn { font-size: 15px; padding: 16px 40px; }

  .sponsor-stats { display: flex; flex-direction: column; gap: 16px; }
  .stat-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 24px 28px;
    text-align: center;
  }
  .stat-num { font-size: 40px; font-weight: 900; color: #fff; line-height: 1; margin-bottom: 8px; }
  .stat-num span { font-size: 18px; color: rgba(255,180,0,0.8); }
  .stat-label { font-size: 12px; color: rgba(255,255,255,0.35); }

  /* ===== 掲載申請バナー ===== */
  .apply-banner {
    padding: 40px 48px;
    background: rgba(0,220,100,0.06);
    border: 1px solid rgba(0,220,100,0.2);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .apply-banner h3 { font-size: 18px; font-weight: 700; color: #fff; margin-bottom: 6px; }
  .apply-banner p { font-size: 14px; color: rgba(255,255,255,0.5); }

  /* ===== レスポンシブ ===== */
  @media (max-width: 900px) {
    .countdown-layout { grid-template-columns: 1fr; }
    .cd-list { flex-direction: row; overflow-x: auto; gap: 8px; padding-bottom: 4px; }
    .cd-list-item { min-width: 200px; }
    .sponsor-inner { grid-template-columns: 1fr; gap: 40px; }
    .sponsor-stats { flex-direction: row; }
    .stat-card { flex: 1; padding: 20px; }
    .stat-num { font-size: 28px; }
    .row-name-wrap { width: 160px; }
    .filter-bar { gap: 16px; }
  }
  @media (max-width: 640px) {
    .row-main { flex-direction: column; align-items: flex-start; gap: 6px; }
    .row-name-wrap { width: 100%; }
    .row-meta { gap: 8px; }
    .row-right { display: none; }
    .sponsor-stats { flex-direction: column; }
    .apply-banner { padding: 28px 24px; }
    .filter-bar { padding: 16px; }
  }
</style>

<script>
  // ===== カウントダウン =====
  const dataEl = document.getElementById('festival-data');
  const layout = document.getElementById('countdown-layout');

  if (dataEl && layout) {
    const festivalsData: any[] = JSON.parse(dataEl.textContent ?? '[]');
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    function getCountdownInfo(f: { startDate: string; endDate?: string }) {
      const start = new Date(f.startDate + 'T00:00:00');
      const end = f.endDate ? new Date(f.endDate + 'T00:00:00') : new Date(f.startDate + 'T00:00:00');
      if (today > end) return null;
      const daysToStart = Math.round((start.getTime() - today.getTime()) / 86400000);
      if (daysToStart > 0) return { num: String(daysToStart), unit: '日後', type: 'upcoming' };
      if (daysToStart === 0) return { num: '本日', unit: '開催！', type: 'today' };
      if (today <= end) return { num: String(Math.abs(daysToStart) + 1), unit: '日目', type: 'ongoing' };
      return null;
    }

    const upcoming = festivalsData
      .map((f: any) => ({ ...f, info: getCountdownInfo(f) }))
      .filter((f: any) => f.info !== null)
      .sort((a: any, b: any) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime())
      .slice(0, 5);

    layout.innerHTML = '';

    if (upcoming.length === 0) {
      layout.innerHTML = '<p style="color:rgba(255,255,255,0.2);font-size:13px">開催予定を確認中...</p>';
    } else {
      const [first, ...rest] = upcoming;
      const fc = first.info.type;
      const featClass = fc === 'today' ? 'cd-featured--today' : fc === 'ongoing' ? 'cd-featured--ongoing' : '';
      const featTag = first.slug ? 'a' : 'div';
      const featHref = first.slug ? `href="/festivals/${first.slug}"` : '';
      const reachHtml = first.reach
        ? `<div class="cd-feat-reach"><div class="cd-feat-reach-num">${first.reach}</div><div class="cd-feat-reach-label">想定来場者</div></div>` : '';
      const sponsorHtml = first.sponsorStatus === 'open'
        ? `<a href="/contact" style="font-size:12px;color:#ffb400;text-decoration:none;font-weight:700;z-index:2;position:relative;" onClick="event.stopPropagation()">広告のご相談 →</a>` : '';

      const featuredHtml = `
        <${featTag} ${featHref} class="cd-featured ${featClass}">
          <div class="cd-feat-top">
            <div class="cd-feat-count">
              <span class="cd-feat-num">${first.info.num}</span>
              <span class="cd-feat-unit">${first.info.unit}</span>
            </div>
            ${reachHtml}
          </div>
          <div class="cd-feat-divider"></div>
          <div class="cd-feat-name">${first.festivalName}</div>
          <div class="cd-feat-univ">${first.university}</div>
          <div class="cd-feat-date">🗓 ${first.dateText}</div>
          <div class="cd-feat-footer">
            <span class="cd-feat-pref">📍 ${first.prefecture}</span>
            ${first.slug ? `<span class="cd-feat-cta">詳細を見る →</span>` : sponsorHtml}
          </div>
        </${featTag}>
      `;

      const listItems = rest.map(f => {
        const badgeClass = f.info.type === 'ongoing' ? 'cd-list-badge--ongoing' : '';
        const badgeText = f.info.type === 'ongoing' ? `${f.info.num}日目` : `${f.info.num}日後`;
        const itemTag = f.slug ? 'a' : 'div';
        const itemHref = f.slug ? `href="/festivals/${f.slug}"` : '';
        return `
          <${itemTag} ${itemHref} class="cd-list-item">
            <span class="cd-list-badge ${badgeClass}">${badgeText}</span>
            <div class="cd-list-info">
              <div class="cd-list-name">${f.festivalName}</div>
              <div class="cd-list-sub">${f.university} · ${f.prefecture}</div>
            </div>
            <span class="cd-list-arrow">→</span>
          </${itemTag}>
        `;
      }).join('');

      layout.innerHTML = `
        ${featuredHtml}
        <div class="cd-list">${listItems}</div>
      `;
    }
  }

  // ===== フィルター =====
  const monthBtns   = document.querySelectorAll<HTMLElement>('[data-filter="month"]');
  const prefBtns    = document.querySelectorAll<HTMLElement>('[data-filter="pref"]');
  const sponsorBtns = document.querySelectorAll<HTMLElement>('[data-filter="sponsor"]');
  const countEl     = document.getElementById('result-num');

  let activeMonth   = 'all';
  let activePref    = 'all';
  let activeSponsor = 'all';

  function updateChips(btns: NodeListOf<HTMLElement>, active: string) {
    btns.forEach(b => b.classList.toggle('chip--active', b.dataset.value === active));
  }

  function applyFilter() {
    let total = 0;
    document.querySelectorAll<HTMLElement>('.month-group').forEach(group => {
      const monthMatch = activeMonth === 'all' || group.dataset.month === activeMonth;
      const rows = group.querySelectorAll<HTMLElement>('.festival-row');
      let visible = 0;
      rows.forEach(row => {
        const pMatch = activePref    === 'all' || row.dataset.pref    === activePref;
        const sMatch = activeSponsor === 'all' || row.dataset.sponsor === activeSponsor;
        const show = monthMatch && pMatch && sMatch;
        row.hidden = !show;
        if (show) visible++;
      });
      group.hidden = visible === 0;
      total += visible;
    });
    if (countEl) countEl.textContent = String(total);
  }

  monthBtns.forEach(btn => btn.addEventListener('click', () => {
    activeMonth = btn.dataset.value ?? 'all';
    updateChips(monthBtns, activeMonth);
    applyFilter();
  }));
  prefBtns.forEach(btn => btn.addEventListener('click', () => {
    activePref = btn.dataset.value ?? 'all';
    updateChips(prefBtns, activePref);
    applyFilter();
  }));
  sponsorBtns.forEach(btn => btn.addEventListener('click', () => {
    activeSponsor = btn.dataset.value ?? 'all';
    updateChips(sponsorBtns, activeSponsor);
    applyFilter();
  }));
</script>
