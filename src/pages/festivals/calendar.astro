  .cd-bottom {
    padding: 18px 24px 22px;
    background: #111;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .cd-name {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    line-height: 1.3;
  }
  .cd-univ {
    font-size: 13px;
    color: rgba(255,255,255,0.45);
    margin-bottom: 4px;
  }
  .cd-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .cd-tag {
    font-size: 10px;
    font-weight: 700;
    padding: 3px 10px;
    border-radius: 20px;
  }
  .cd-tag--pref {
