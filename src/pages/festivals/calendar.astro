    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    color: #fff;
    line-height: 1.3;
    margin-bottom: 20px;
  }
  .sponsor-desc {
    font-size: 15px;
    color: rgba(255,255,255,0.5);
    line-height: 1.9;
    margin-bottom: 36px;
  }
  .sponsor-points {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 40px;
  }
  .sponsor-point {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }
  .point-icon {
    font-size: 22px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .sponsor-point strong {
    display: block;
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 4px;
  }
  .sponsor-point p {
    font-size: 13px;
    color: rgba(255,255,255,0.4);
    line-height: 1.6;
    margin: 0;
  }
  .sponsor-cta-btn { font-size: 15px; padding: 16px 40px; }

  .sponsor-stats {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .stat-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 24px 28px;
    text-align: center;
  }
  .stat-num {
    font-size: 40px;
    font-weight: 900;
    color: #fff;
