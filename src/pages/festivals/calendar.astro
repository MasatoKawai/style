    border: 1px solid rgba(0,220,100,0.3);
  }
  .cd-tag--student {
    color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .cd-date {
    font-size: 12px;
    color: rgba(255,180,0,0.7);
    margin-top: auto;
