  /* ===== レスポンシブ ===== */
  @media (max-width: 900px) {
    .countdown-grid { grid-template-columns: 1fr; gap: 10px; }
    .countdown-skeleton { height: 120px; }
    .sponsor-inner { grid-template-columns: 1fr; gap: 40px; }
    .sponsor-stats { flex-direction: row; }
    .stat-card { flex: 1; padding: 20px; }
    .stat-num { font-size: 28px; }
  }
  @media (max-width: 600px) {
    .sponsor-stats { flex-direction: column; }
    .apply-banner { padding: 28px 24px; }
  }
</style>

<script>
  // ===== カウントダウン =====
  const dataEl = document.getElementById('festival-data');
  const grid = document.getElementById('countdown-grid');

  if (dataEl && grid) {
    const festivalsData = JSON.parse(dataEl.textContent ?? '[]');
    const today = new Date();
    today.setHours(0, 0, 0, 0);

    function getCountdownInfo(f: { startDate: string; endDate?: string }) {
      const start = new Date(f.startDate + 'T00:00:00');
      const end = f.endDate ? new Date(f.endDate + 'T00:00:00') : new Date(f.startDate + 'T00:00:00');
      if (today > end) return null;
      const daysToStart = Math.round((start.getTime() - today.getTime()) / 86400000);
      if (daysToStart > 0) return { num: String(daysToStart), unit: '日後', type: 'upcoming' };
      if (daysToStart === 0) return { num: '本日', unit: '開催！', type: 'today' };
      const dayNum = Math.abs(daysToStart) + 1;
      if (today <= end) return { num: String(dayNum), unit: '日目', type: 'ongoing' };
      return null;
    }

    const upcoming = festivalsData
      .map((f: any) => ({ ...f, info: getCountdownInfo(f) }))
      .filter((f: any) => f.info !== null)
      .sort((a: any, b: any) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime())
      .slice(0, 3);

    grid.innerHTML = '';

    for (let i = 0; i < 3; i++) {
      const f = upcoming[i];
      if (!f) {
        grid.insertAdjacentHTML('beforeend', `<div class="cd-empty">開催予定を確認中...</div>`);
        continue;
      }
      const typeClass = f.info.type === 'today' ? 'cd-card--today' : f.info.type === 'ongoing' ? 'cd-card--ongoing' : '';
      const reachHtml = f.reach
        ? `<div class="cd-reach"><span class="cd-reach-num">${f.reach}</span><span class="cd-reach-label">想定来場者</span></div>` : '';
      const studentHtml = f.studentCount
        ? `<span class="cd-tag cd-tag--student">在籍 ${f.studentCount}</span>` : '';
      const sponsorBtn = f.sponsorStatus === 'open'
        ? `<a href="/contact" class="cd-sponsor-btn">📢 広告・スポンサーを相談する</a>` : '';
      const siteLink = f.url
        ? `<a href="${f.url}" target="_blank" rel="noopener" class="cd-link">公式サイト →</a>` : '';
      grid.insertAdjacentHTML('beforeend', `
        <div class="cd-card ${typeClass}">
          <div class="cd-top">
            <div class="cd-top-row">
              <div class="cd-num-wrap">
                <span class="cd-num">${f.info.num}</span>
                <span class="cd-unit">${f.info.unit}</span>
              </div>
              ${reachHtml}
            </div>
          </div>
          <div class="cd-bottom">
            <p class="cd-name">${f.festivalName}</p>
            <p class="cd-univ">${f.university}</p>
            <div class="cd-tags">
              <span class="cd-tag cd-tag--pref">📍 ${f.prefecture}</span>
              ${studentHtml}
            </div>
            <p class="cd-date">🗓 ${f.dateText}</p>
            <div class="cd-actions">
              ${sponsorBtn}
              ${siteLink}
            </div>
          </div>
        </div>
      `);
    }
  }

  // ===== フィルター =====
  const monthBtns  = document.querySelectorAll('[data-filter="month"]');
  const prefBtns   = document.querySelectorAll('[data-filter="pref"]');
  const sponsorBtns = document.querySelectorAll('[data-filter="sponsor"]');
  const cards      = document.querySelectorAll<HTMLElement>('.festival-card');
  const countEl    = document.getElementById('result-num');

  let activeMonth   = 'all';
  let activePref    = 'all';
  let activeSponsor = 'all';

  function updateChips(btns: NodeListOf<Element>, active: string) {
    btns.forEach(b => b.classList.toggle('chip--active', (b as HTMLElement).dataset.value === active));
  }

  function applyFilter() {
    let count = 0;
    cards.forEach(card => {
      const mMatch = activeMonth   === 'all' || card.dataset.month   === activeMonth;
      const pMatch = activePref    === 'all' || card.dataset.pref    === activePref;
      const sMatch = activeSponsor === 'all' || card.dataset.sponsor === activeSponsor;
      const show = mMatch && pMatch && sMatch;
      card.hidden = !show;
      if (show) count++;
    });
    if (countEl) countEl.textContent = String(count);
  }

  monthBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeMonth = (btn as HTMLElement).dataset.value ?? 'all';
      updateChips(monthBtns, activeMonth);
      applyFilter();
    });
  });
  prefBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activePref = (btn as HTMLElement).dataset.value ?? 'all';
      updateChips(prefBtns, activePref);
      applyFilter();
    });
  });
  sponsorBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeSponsor = (btn as HTMLElement).dataset.value ?? 'all';
      updateChips(sponsorBtns, activeSponsor);
      applyFilter();
    });
  });
</script>
