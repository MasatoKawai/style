    background: rgba(255,255,255,0.02);
    border: 1px dashed rgba(255,255,255,0.08);
    border-radius: 16px;
    padding: 40px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    color: rgba(255,255,255,0.2);
  }

  /* ===== フィルター ===== */
  .filter-bar {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 32px;
    padding: 28px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
  }
  .filter-label {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 1px;
    display: block;
    margin-bottom: 10px;
  }
  .filter-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip {
    padding: 6px 16px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.5);
    font-size: 13px;
    cursor: pointer;
    border-radius: 20px;
    transition: all 0.2s;
  }
  .chip:hover { border-color: #00dc64; color: #00dc64; }
  .chip--active { background: #00dc64; border-color: #00dc64; color: #000; font-weight: 700; }

  .result-count {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    margin-bottom: 24px;
  }
  .result-count span { color: #00dc64; font-weight: 700; }

  /* ===== カードグリッド ===== */
  .festivals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 2px;
  }
  .festival-card {
    background: var(--bg-card);
    padding: 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: background 0.2s;
  }
  .festival-card:hover { background: #1a1a1a; }
  .festival-card[hidden] { display: none; }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .festival-month {
    font-size: 11px;
    font-weight: 700;
    color: #00dc64;
    letter-spacing: 1px;
    border: 1px solid rgba(0,220,100,0.3);
    display: inline-block;
    padding: 2px 10px;
    border-radius: 20px;
  }
  .sponsor-badge {
    font-size: 10px;
    font-weight: 700;
    color: #00dc64;
    background: rgba(0,220,100,0.1);
    border: 1px solid rgba(0,220,100,0.3);
    padding: 2px 10px;
    border-radius: 20px;
    white-space: nowrap;
  }
  .sponsor-badge--closed {
    color: rgba(255,255,255,0.3);
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.1);
  }

  .festival-name {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    line-height: 1.4;
  }
  .festival-univ { font-size: 13px; color: rgba(255,255,255,0.5); }
  .festival-date { font-size: 13px; color: rgba(255,180,0,0.8); }
  .festival-pref { font-size: 12px; color: rgba(255,255,255,0.3); }
  .festival-reach { font-size: 12px; color: rgba(0,220,100,0.6); font-weight: 600; }

  .card-footer {
    margin-top: auto;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .festival-link {
    font-size: 12px;
    color: #00dc64;
    text-decoration: none;
  }
  .festival-link:hover { text-decoration: underline; }
  .sponsor-link {
    font-size: 12px;
    color: #ffb400;
    text-decoration: none;
  }
  .sponsor-link:hover { text-decoration: underline; }

  /* ===== スポンサーCTA ===== */
  .sponsor-section {
    background: #080808;
    padding: 80px 0;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .sponsor-inner {
