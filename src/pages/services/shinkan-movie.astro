---
import Layout from '../../layouts/Layout.astro';

const flowSteps = ['お問い合わせ', '企画ヒアリング', 'PV撮影・編集', '素材確認', '当日上映'];
const orgFeatures = [
  { icon: '🎬', title: 'PV制作を丸投げできる', desc: '構成案・撮影・編集まですべてお任せ。動画制作の経験がなくても大丈夫です。' },
  { icon: '📽️', title: '大スクリーンで上映', desc: '90分の上映枠の中で、あなたの団体の魅力を映画館クオリティで届けます。' },
  { icon: '📲', title: 'SNS・プラットフォーム告知', desc: '上映前後のSNS告知から新歓プラットフォームへの掲載まで、集客をトータル支援します。' },
  { icon: '🎓', title: '新入生に直接リーチ', desc: '映画館に足を運んだ意欲的な新入生と、イベント当日に直接つながるチャンスです。' },
];
const timeline = [
  { date: '2026年 秋〜冬', title: '団体・スポンサー募集開始', desc: '参加団体・協賛企業の募集を開始。定員に達し次第締め切り。' },
  { date: '2027年 1〜3月', title: 'PV制作・素材確定', desc: '各団体のヒアリングをもとに動画を制作。3月末までに上映素材を確定。' },
  { date: '2027年 4月', title: '新歓映画館 開催', desc: '北海道大学近隣の映画館にて90分の上映イベントを開催。' },
  { date: '開催後', title: 'レポート・フォローアップ', desc: '来場者数・リーチ数などの実績レポートをスポンサー・団体へご報告。' },
];
---

<Layout
  title="新歓映画館 2027 | Strategy& × 北海道大学"
  description="北海道大学の新入生に向けて、サークル・部活のPVを映画館で上映。30団体・90分のシネマティック新歓イベント、2027年4月開催予定。"
>

  <!-- ===== HERO ===== -->
  <section class="sm-hero">
    <div class="film-strip"></div>
    <div class="container sm-hero-inner">
      <p class="sm-badge">Hokkaido University × 2027 Spring</p>
      <h1 class="sm-title">
        <span class="sm-title-sub">北大新歓</span>
        映画館
      </h1>
      <p class="sm-tagline">あなたのサークルが、スクリーンに輝く。</p>
      <div class="sm-meta">
        <div class="sm-meta-item"><strong>30</strong><small>参加団体</small></div>
        <div class="sm-meta-item"><strong>90</strong><small>分の上映</small></div>
        <div class="sm-meta-item"><strong>2027.4</strong><small>開催予定</small></div>
      </div>
      <div class="sm-hero-ctas">
        <a href="#org" class="btn btn--gold">団体の方はこちら</a>
        <a href="#sponsor" class="btn btn--outline">協賛・広告掲載</a>
      </div>
    </div>
    <div class="sm-scroll">
      <span>SCROLL</span><span>↓</span>
    </div>
    <div class="film-strip sm-film-bottom"></div>
  </section>

  <!-- ===== コンセプト ===== -->
  <section class="section section--dark">
    <div class="container">
      <p class="section-label">Concept</p>
      <div class="section-divider"></div>
      <h2 class="section-title">映画館で届ける、<br>いちばん熱い新歓</h2>
      <p class="section-lead">
        北海道大学の新入生が集まる春、サークル・部活の魅力を映画館のスクリーンで届ける。
        動画制作から当日の演出まで、Strategy&amp;が丸ごとサポートします。
      </p>
      <div class="concept-grid">
        <div class="concept-card">
          <span class="concept-num">01</span>
          <h3>PV・動画制作</h3>
          <p>企画・撮影・編集まで一貫してサポート。映画館クオリティの映像で団体の魅力を引き出します。</p>
        </div>
        <div class="concept-card">
          <span class="concept-num">02</span>
          <h3>映画館上映</h3>
          <p>大スクリーン・高音質での上映で、チラシやSNSにはない圧倒的な没入体験を新入生に提供。</p>
        </div>
        <div class="concept-card">
          <span class="concept-num">03</span>
          <h3>プラットフォーム連携</h3>
          <p>上映後も新入生がいつでも情報を見返せるよう、北大新歓デジタルパンフレットと連動します。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 団体向け ===== -->
  <section id="org" class="section section--light">
    <div class="container">
      <p class="section-label section-label--dark">For Organizations</p>
      <div class="section-divider section-divider--purple"></div>
      <h2 class="section-title" style="color:var(--text-dark)">サークル・部活の皆さんへ</h2>
      <p class="section-lead section-lead--dark">
        動画が作れない・何から始めれば良いかわからない──<br>
        そんな団体こそ歓迎です。企画の段階から伴走します。
      </p>
      <div class="org-features">
        {orgFeatures.map(f => (
          <div class="org-feature">
            <span class="org-feature-icon">{f.icon}</span>
            <h3>{f.title}</h3>
            <p>{f.desc}</p>
          </div>
        ))}
      </div>
      <div class="org-flow">
        <h3>参加までの流れ</h3>
        <div class="flow-steps">
          {flowSteps.map((step, i) => (
            <div class="flow-step">
              <span class="flow-num">{i + 1}</span>
              <p>{step}</p>
              {i < flowSteps.length - 1 && <span class="flow-arrow">→</span>}
            </div>
          ))}
        </div>
      </div>
      <div style="text-align:center; margin-top:48px">
        <a href="#contact" class="btn btn--purple">参加を申し込む・相談する</a>
        <p style="margin-top:14px; font-size:13px; color:#999">定員30団体 ／ 参加費・料金については個別にご相談ください</p>
      </div>
    </div>
  </section>

  <!-- ===== スポンサー向け ===== -->
  <section id="sponsor" class="section section--darker">
    <div class="container">
      <p class="section-label">For Sponsors</p>
      <div class="section-divider"></div>
      <h2 class="section-title">企業・団体の皆さまへ</h2>
      <p class="section-lead">
        北海道大学の新入生・サークルリーダー層にピンポイントでリーチできる広告枠をご提供します。
      </p>
      <div class="sponsor-stats">
        <div class="sponsor-stat"><strong>30+</strong><span>参加サークル</span></div>
        <div class="sponsor-stat"><strong>90</strong><span>分の上映時間</span></div>
        <div class="sponsor-stat"><strong>北大</strong><span>集中開催</span></div>
        <div class="sponsor-stat"><strong>春</strong><span>入学直後リーチ</span></div>
      </div>
      <div class="sponsor-plans">
        <div class="plan">
          <p class="plan-name">Standard</p>
          <h3>スタンダードプラン</h3>
          <ul>
            <li>上映前スライド広告掲載</li>
            <li>新歓プラットフォームバナー掲載</li>
            <li>当日配布物へのロゴ掲載</li>
          </ul>
          <a href="#contact" class="btn btn--gold" style="width:100%; justify-content:center">詳細・お問い合わせ</a>
        </div>
        <div class="plan plan--featured">
          <p class="plan-featured-badge">RECOMMEND</p>
          <p class="plan-name">Premium</p>
          <h3>プレミアムプラン</h3>
          <ul>
            <li>上映内CM枠（30秒）</li>
            <li>スタンダードプランの全特典</li>
            <li>会場内ブース設置権</li>
            <li>SNS投稿でのロゴタグ付け</li>
            <li>イベントレポート記事掲載</li>
          </ul>
          <a href="#contact" class="btn btn--gold" style="width:100%; justify-content:center">詳細・お問い合わせ</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== スケジュール ===== -->
  <section class="section section--light">
    <div class="container--narrow">
      <p class="section-label section-label--dark">Schedule</p>
      <div class="section-divider section-divider--purple"></div>
      <h2 class="section-title" style="color:var(--text-dark)">スケジュール</h2>
      <div class="timeline">
        {timeline.map(item => (
          <div class="tl-item">
            <p class="tl-date">{item.date}</p>
            <div class="tl-content">
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section id="contact" class="sm-footer-cta">
    <div class="film-strip"></div>
    <div class="container--narrow" style="text-align:center; padding:80px 24px">
      <h2>まずは、話を聞いてみませんか？</h2>
      <p>団体・スポンサーどちらもお気軽にご連絡ください。</p>
      <div class="footer-cta-btns">
        <a href="mailto:info@strategy-and.art" class="btn btn--gold">メールで問い合わせる</a>
        <a href="/contact" class="btn btn--outline">お問い合わせフォーム</a>
      </div>
    </div>
    <div class="film-strip"></div>
  </section>

</Layout>

<style>
  /* ===== HERO ===== */
  .sm-hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    background: linear-gradient(160deg, #0a0a0a 0%, #1a0a2e 50%, #0d1a3a 100%);
    overflow: hidden;
  }
  .sm-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 40% at 50% 60%, rgba(255,180,0,0.07) 0%, transparent 70%),
      radial-gradient(ellipse 80% 60% at 20% 80%, rgba(80,40,180,0.1) 0%, transparent 60%);
    pointer-events: none;
  }
  .sm-film-bottom { position: absolute; bottom: 0; left: 0; right: 0; }
  .sm-hero-inner {
    position: relative; z-index: 1;
    padding: 120px 24px 80px;
    text-align: center;
  }
  .sm-badge {
    display: inline-block;
    border: 1px solid rgba(255,180,0,0.5);
    color: rgba(255,180,0,0.85);
    font-size: 11px;
    letter-spacing: 3px;
    padding: 6px 20px;
    border-radius: 2px;
    margin-bottom: 32px;
    text-transform: uppercase;
  }
  .sm-title {
    font-size: clamp(52px, 12vw, 100px);
    font-weight: 900;
    color: #fff;
    line-height: 1.0;
    margin-bottom: 20px;
  }
  .sm-title-sub {
    display: block;
    font-size: clamp(14px, 3vw, 22px);
    font-weight: 400;
    letter-spacing: 8px;
    color: rgba(255,180,0,0.8);
    margin-bottom: 8px;
  }
  .sm-tagline {
    font-size: clamp(14px, 2vw, 17px);
    color: rgba(255,255,255,0.5);
    letter-spacing: 2px;
    margin-bottom: 48px;
  }
  .sm-meta {
    display: flex;
    gap: 40px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 48px;
  }
  .sm-meta-item { text-align: center; }
  .sm-meta-item strong {
    display: block;
    font-size: clamp(32px, 6vw, 52px);
    font-weight: 900;
    color: rgba(255,180,0,0.9);
    line-height: 1;
    margin-bottom: 6px;
  }
  .sm-meta-item small { font-size: 12px; color: rgba(255,255,255,0.4); letter-spacing: 2px; }
  .sm-hero-ctas { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }
  .sm-scroll {
    position: absolute;
    bottom: 36px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: rgba(255,255,255,0.2);
    font-size: 10px;
    letter-spacing: 3px;
    animation: bounce 2.2s infinite;
    z-index: 1;
  }
  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* ===== コンセプト ===== */
  .concept-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 56px;
  }
  .concept-card {
    background: var(--bg-card);
    padding: 40px 28px;
    position: relative;
  }
  .concept-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: rgba(255,180,0,0.35);
  }
  .concept-num {
    display: block;
    font-size: 44px;
    font-weight: 900;
    color: rgba(255,180,0,0.1);
    line-height: 1;
    margin-bottom: 16px;
  }
  .concept-card h3 { font-size: 17px; font-weight: 700; color: #fff; margin-bottom: 10px; }
  .concept-card p { font-size: 13px; color: rgba(255,255,255,0.5); line-height: 1.8; }

  /* ===== 団体向け ===== */
  .org-features {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 52px;
  }
  .org-feature {
    border: 1px solid #eee;
    border-radius: 8px;
    padding: 28px 24px;
    transition: box-shadow 0.2s;
  }
  .org-feature:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.07); }
  .org-feature-icon { font-size: 28px; margin-bottom: 12px; }
  .org-feature h3 { font-size: 16px; font-weight: 700; color: var(--text-dark); margin-bottom: 8px; }
  .org-feature p { font-size: 13px; color: var(--text-mid); line-height: 1.8; }
  .org-flow {
    margin-top: 56px;
    background: #f0eeff;
    border-radius: 10px;
    padding: 36px;
  }
  .org-flow h3 { font-size: 15px; font-weight: 700; color: var(--text-dark); margin-bottom: 28px; }
  .flow-steps {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }
  .flow-step {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .flow-num {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(74,40,180,0.12);
    color: var(--purple);
    font-size: 13px;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .flow-step p { font-size: 13px; color: var(--text-mid); white-space: nowrap; }
  .flow-arrow { color: #ccc; font-size: 14px; }

  /* ===== スポンサー ===== */
  .sponsor-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 52px;
  }
  .sponsor-stat {
    background: var(--bg-card);
    padding: 36px 20px;
    text-align: center;
  }
  .sponsor-stat strong {
    display: block;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 900;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 10px;
  }
  .sponsor-stat span { font-size: 12px; color: rgba(255,255,255,0.4); letter-spacing: 1px; }
  .sponsor-plans {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2px;
    margin-top: 40px;
  }
  .plan { background: var(--bg-card); padding: 40px 32px; position: relative; }
  .plan--featured { background: #1c1230; }
  .plan-featured-badge {
    position: absolute;
    top: -1px; right: 24px;
    background: var(--gold);
    color: var(--bg-dark);
    font-size: 10px;
    font-weight: 700;
    padding: 4px 12px;
    letter-spacing: 1px;
  }
  .plan-name { font-size: 11px; letter-spacing: 3px; color: rgba(255,180,0,0.65); text-transform: uppercase; margin-bottom: 12px; }
  .plan h3 { font-size: 20px; font-weight: 700; color: #fff; margin-bottom: 20px; }
  .plan ul { list-style: none; margin-bottom: 28px; }
  .plan ul li {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
    padding: 8px 0;
    border-bottom: 1px solid rgba(255,255,255,0.05);
    display: flex;
    align-items: flex-start;
    gap: 8px;
  }
  .plan ul li::before { content: '✓'; color: rgba(255,180,0,0.7); flex-shrink: 0; }

  /* ===== タイムライン ===== */
  .timeline {
    margin-top: 52px;
    padding-left: 28px;
    border-left: 2px solid rgba(74,40,180,0.25);
  }
  .tl-item {
    position: relative;
    padding-bottom: 36px;
    padding-left: 24px;
  }
  .tl-item:last-child { padding-bottom: 0; }
  .tl-item::before {
    content: '';
    position: absolute;
    left: -33px;
    top: 5px;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--purple);
    border: 2px solid #f6f6f6;
    box-shadow: 0 0 0 2px rgba(74,40,180,0.3);
  }
  .tl-date { font-size: 11px; font-weight: 700; color: var(--purple); letter-spacing: 2px; margin-bottom: 6px; }
  .tl-content h3 { font-size: 16px; font-weight: 700; color: var(--text-dark); margin-bottom: 6px; }
  .tl-content p { font-size: 13px; color: var(--text-mid); }

  /* ===== フッターCTA ===== */
  .sm-footer-cta {
    background: linear-gradient(160deg, #1a0a2e 0%, #0d1a3a 100%);
  }
  .sm-footer-cta h2 { font-size: clamp(22px, 4vw, 36px); font-weight: 900; color: #fff; margin-bottom: 14px; }
  .sm-footer-cta p { font-size: 15px; color: rgba(255,255,255,0.45); margin-bottom: 36px; }
  .footer-cta-btns { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  /* ===== レスポンシブ ===== */
  @media (max-width: 768px) {
    .concept-grid { grid-template-columns: 1fr; }
    .org-features { grid-template-columns: 1fr; }
    .sponsor-stats { grid-template-columns: repeat(2, 1fr); }
    .sponsor-plans { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .flow-steps { flex-direction: column; align-items: flex-start; }
    .flow-arrow { transform: rotate(90deg); }
  }
</style>
