---
import Layout from '../../layouts/Layout.astro';
import { festivals, prefectures, months } from '../../data/festivals';

const monthNames: Record<number, string> = {
  1:'1月', 2:'2月', 3:'3月', 4:'4月', 5:'5月', 6:'6月',
  7:'7月', 8:'8月', 9:'9月', 10:'10月', 11:'11月', 12:'12月'
};
---

<Layout
  title="学祭カレンダー 2025 | 大学スタイル"
  description="全国の大学祭・学園祭の開催日程を月別・地域別に一覧。2025年の学祭情報をまとめています。"
>

  <!-- ===== ページヒーロー ===== -->
  <section class="page-hero">
    <div class="film-strip"></div>
    <div class="container page-hero-inner">
      <p class="section-label" style="color:rgba(0,220,100,0.8)">大学スタイル</p>
      <h1 class="page-hero-title">学祭カレンダー <span class="year">2025</span></h1>
      <p class="page-hero-sub">全国の大学祭・学園祭の開催日程一覧</p>
    </div>
    <div class="film-strip film-strip--bottom"></div>
  </section>

  <!-- ===== フィルター + リスト ===== -->
  <section class="section section--dark">
    <div class="container">

      <!-- フィルターUI -->
      <div class="filter-bar">
        <div class="filter-group">
          <label class="filter-label">月で絞り込む</label>
          <div class="filter-chips" id="month-filters">
            <button class="chip chip--active" data-filter="month" data-value="all">すべて</button>
            {months.map(m => (
              <button class="chip" data-filter="month" data-value={m}>{monthNames[m]}</button>
            ))}
          </div>
        </div>
        <div class="filter-group">
          <label class="filter-label">地域で絞り込む</label>
          <div class="filter-chips" id="pref-filters">
            <button class="chip chip--active" data-filter="pref" data-value="all">すべて</button>
            {prefectures.map(p => (
              <button class="chip" data-filter="pref" data-value={p}>{p}</button>
            ))}
          </div>
        </div>
      </div>

      <!-- 件数表示 -->
      <p class="result-count"><span id="result-num">{festivals.length}</span>件の学祭</p>

      <!-- カード一覧 -->
      <div class="festivals-grid" id="festivals-grid">
        {festivals.map(f => (
          <div
            class="festival-card"
            data-month={f.month}
            data-pref={f.prefecture}
          >
            <div class="festival-month">{monthNames[f.month]}</div>
            <div class="festival-body">
              <h3 class="festival-name">{f.festivalName}</h3>
              <p class="festival-univ">{f.university}</p>
              <p class="festival-date">{f.dateText}</p>
              <p class="festival-pref">📍 {f.prefecture}</p>
            </div>
            {f.url && (
              <a href={f.url} target="_blank" rel="noopener" class="festival-link">公式サイト →</a>
            )}
          </div>
        ))}
      </div>

      <!-- 掲載申請バナー -->
      <div class="apply-banner">
        <div>
          <h3>あなたの学祭を掲載しませんか？</h3>
          <p>情報の追加・修正はお気軽にご連絡ください。</p>
        </div>
        <a href="/contact" class="btn btn--gold">掲載申請・修正依頼</a>
      </div>

    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding: 160px 0 80px;
    background: linear-gradient(150deg, #0a0a0a 0%, #0a1a10 100%);
    position: relative;
    overflow: hidden;
  }
  .film-strip--bottom { position: absolute; bottom: 0; left: 0; right: 0; }
  .page-hero-inner { position: relative; z-index: 1; }
  .page-hero-title {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 900;
    color: #fff;
    margin-bottom: 12px;
  }
  .page-hero-title .year { color: #00dc64; }
  .page-hero-sub {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    letter-spacing: 3px;
  }

  /* フィルター */
  .filter-bar {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 32px;
    padding: 28px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.07);
  }
  .filter-label {
    font-size: 12px;
    color: rgba(255,255,255,0.4);
    letter-spacing: 1px;
    display: block;
    margin-bottom: 10px;
  }
  .filter-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip {
    padding: 6px 16px;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.5);
    font-size: 13px;
    cursor: pointer;
    border-radius: 20px;
    transition: all 0.2s;
  }
  .chip:hover { border-color: #00dc64; color: #00dc64; }
  .chip--active { background: #00dc64; border-color: #00dc64; color: #000; font-weight: 700; }

  .result-count {
    font-size: 13px;
    color: rgba(255,255,255,0.35);
    margin-bottom: 24px;
  }
  .result-count span { color: #00dc64; font-weight: 700; }

  /* カードグリッド */
  .festivals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 2px;
  }
  .festival-card {
    background: var(--bg-card);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: background 0.2s;
  }
  .festival-card:hover { background: #1a1a1a; }
  .festival-card[hidden] { display: none; }

  .festival-month {
    font-size: 11px;
    font-weight: 700;
    color: #00dc64;
    letter-spacing: 1px;
    border: 1px solid rgba(0,220,100,0.3);
    display: inline-block;
    padding: 2px 10px;
    border-radius: 20px;
    width: fit-content;
  }
  .festival-name {
    font-size: 16px;
    font-weight: 700;
    color: #fff;
    line-height: 1.4;
  }
  .festival-univ {
    font-size: 13px;
    color: rgba(255,255,255,0.5);
  }
  .festival-date {
    font-size: 13px;
    color: rgba(255,180,0,0.8);
  }
  .festival-pref {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
  }
  .festival-link {
    font-size: 12px;
    color: #00dc64;
    text-decoration: none;
    margin-top: auto;
  }
  .festival-link:hover { text-decoration: underline; }

  /* 掲載申請バナー */
  .apply-banner {
    margin-top: 64px;
    padding: 40px 48px;
    background: rgba(0,220,100,0.06);
    border: 1px solid rgba(0,220,100,0.2);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    flex-wrap: wrap;
  }
  .apply-banner h3 {
    font-size: 18px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 6px;
  }
  .apply-banner p {
    font-size: 14px;
    color: rgba(255,255,255,0.5);
  }
</style>

<script>
  const monthBtns = document.querySelectorAll('[data-filter="month"]');
  const prefBtns  = document.querySelectorAll('[data-filter="pref"]');
  const cards     = document.querySelectorAll<HTMLElement>('.festival-card');
  const countEl   = document.getElementById('result-num');

  let activeMonth = 'all';
  let activePref  = 'all';

  function updateChips(btns: NodeListOf<Element>, active: string) {
    btns.forEach(b => {
      b.classList.toggle('chip--active', (b as HTMLElement).dataset.value === active);
    });
  }

  function applyFilter() {
    let count = 0;
    cards.forEach(card => {
      const mMatch = activeMonth === 'all' || card.dataset.month === activeMonth;
      const pMatch = activePref  === 'all' || card.dataset.pref  === activePref;
      const show = mMatch && pMatch;
      card.hidden = !show;
      if (show) count++;
    });
    if (countEl) countEl.textContent = String(count);
  }

  monthBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeMonth = (btn as HTMLElement).dataset.value ?? 'all';
      updateChips(monthBtns, activeMonth);
      applyFilter();
    });
  });

  prefBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activePref = (btn as HTMLElement).dataset.value ?? 'all';
      updateChips(prefBtns, activePref);
      applyFilter();
    });
  });
</script>
